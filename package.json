{
  "name": "api-infinity-check",
  "version": "1.0.0",
  "description": "NestJS + MikroORM + PostgreSQL API",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "build": "nest build",
    "migration:create": "mikro-orm migration:create --config ./src/config/mikro-orm.config.ts",
    "migration:up": "mikro-orm migration:up --config ./src/config/mikro-orm.config.ts",
    "migration:down": "mikro-orm migration:down --config ./src/config/mikro-orm.config.ts",
    "seeder:run": "mikro-orm seeder:run --config ./src/config/mikro-orm.config.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\""
  },
  "dependencies": {
    "@mikro-orm/core": "^6.3.13",
    "@mikro-orm/postgresql": "^6.3.13",
    "@mikro-orm/nestjs": "^6.0.2",
    "@mikro-orm/migrations": "^6.3.13",
    "@mikro-orm/seeder": "^6.3.13",
    "@mikro-orm/cli": "^6.3.13",
    "@nestjs/common": "^10.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/platform-express": "^10.4.20",
    "@nestjs/config": "^4.0.2",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/swagger": "^7.4.2",
    "helmet": "^8.1.0",
    "joi": "^18.0.2",
    "class-validator": "^0.14.1",
    "class-transformer": "^0.5.1",
    "class-sanitizer": "^1.0.1",
    "bcryptjs": "^2.4.3",
    "passport-jwt": "^4.0.1",
    "passport": "^0.7.0",
    "dotenv": "^16.5.0",
    "js-yaml": "^4.1.1",
    "swagger-ui-express": "^5.0.1",
    "pg": "^8.13.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.0.0",
    "@nestjs/schematics": "^10.0.0",
    "@nestjs/testing": "^10.0.0",
    "@types/express": "^4.17.17",
    "@types/jest": "^29.5.2",
    "@types/node": "^20.3.1",
    "@types/supertest": "^6.0.0",
    "@types/bcryptjs": "^2.4.2",
    "@types/passport-jwt": "^4.0.1",
    "@types/js-yaml": "^4.0.5",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.42.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "jest": "^29.5.0",
    "prettier": "^3.0.0",
    "source-map-support": "^0.5.21",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.0",
    "ts-loader": "^9.4.3",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.1.3"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": ".",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "./coverage",
    "testEnvironment": "node",
    "moduleNameMapper": {
      "^src/(.*)$": "<rootDir>/src/$1"
    }
  }
}
