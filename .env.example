# Configurações do Servidor
PORT_NUMBER=3000
NODE_ENV=development

# Banco de Dados PostgreSQL
DATABASE_NAME=api_infinity_check
DATABASE_USER=postgres
DATABASE_PASSWORD=sua_senha_aqui_minimo_8_caracteres
DATABASE_HOST=localhost
DATABASE_PORT=5432

# JWT Authentication
# IMPORTANTE: Gere uma chave segura com pelo menos 32 caracteres
# Exemplo: openssl rand -base64 32
JWT_SECRET=sua_chave_jwt_de_pelo_menos_32_caracteres_aqui_mude_isso
JWT_EXPIRES_IN=7d

# Criptografia de Dados em Repouso (AES-256-GCM)
# IMPORTANTE: Deve ter exatamente 64 caracteres hexadecimais (32 bytes)
# Gere com: openssl rand -hex 32
ENCRYPTION_KEY=a1b2c3d4e5f6a1b2c3d4e5f6a1b2c3d4e5f6a1b2c3d4e5f6a1b2c3d4e5f6a1b2

# HTTPS (opcional - desenvolvimento geralmente usa HTTP)
ENABLE_HTTPS=false
SSL_CERT_PATH=/path/to/cert.pem
SSL_KEY_PATH=/path/to/key.pem

# CORS
CORS_ORIGIN=http://localhost:3000
CORS_CREDENTIALS=true
